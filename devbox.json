{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.5/.schema/devbox.schema.json",
  "packages": [
    "cargo-make@latest",
    "rustup@latest",
    "libiconv@latest",
    "committed@1.1.11"
  ],
  "env": {
    "PROJECT_DIR": "$PWD",
    "RUSTUP_HOME": "$PWD/.devbox/rustup",
    "CARGO_HOME": "$PWD/.devbox/cargo",
    "PATH": "$PWD/.devbox/cargo/bin:$PATH"
  },
  "shell": {
    "init_hook": [
      "mkdir -p \"$RUSTUP_HOME\" \"$CARGO_HOME\"",
      "export LIBRARY_PATH=\"$PROJECT_DIR/.devbox/nix/profile/default/lib:$LIBRARY_PATH\"",
      "rustup default stable"
    ]
  }
}
